BUILD_OUTPUT=$(NODE_OPTIONS="--no-deprecation" bun run build 2>&1)
BUILD_EXIT=$?

if [ $BUILD_EXIT -ne 0 ]; then
  echo "$BUILD_OUTPUT" | \
    grep -v "DEP0180" | \
    grep -v "The build was canceled" | \
    grep -E "(ERROR|error|Error|‚úò|Failed|failed|warning.*ts\([0-9]+\))" || echo "$BUILD_OUTPUT"
  echo "pre-push failed"
  exit 1
fi
