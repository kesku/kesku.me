---
import { Icon } from "astro-icon/components";

import exaLogo from "@/assets/exa-color.svg";
import Brackets from "@/components/Brackets.astro";
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout meta={{ title: "Home" }}>
	<section class="mb-16">
		<div class="mb-8 flex items-center gap-4">
			<div class="h-1 w-12 bg-accent"></div>
			<span class="text-sm font-medium uppercase tracking-widest text-accent">hiya! I'm kesku</span>
		</div>

		<h1 class="title mb-6">But you can call me Kes!</h1>
		<p class="mb-6 leading-relaxed">I work on making APIs actually usable</p>

		<p class="mb-6 leading-relaxed">
			I'm a self-taught dev from the UK, former cs student (dropped out), and <a
				class="text-accent transition-all hover:underline hover:underline-offset-2"
				href="https://x.com/yoimnotkesku/status/1811161077037801698"
				rel="noopener noreferrer"
				target="_blank">train enjoyer</a
			>
		</p>
		<p class="leading-relaxed">
			I spend most of my time working as Developer Relations Engineer at
			<a
				class="text-accent transition-all hover:underline hover:underline-offset-2"
				href="https://exa.ai/"
				rel="noopener noreferrer"
				target="_blank">Exa Labs</a
			>, helping make search feel obvious, useful, and genuinely fun to build with.<br /><br />
			That usually means:
		</p>
		<ul class="my-4 list-disc space-y-2 ps-5 leading-relaxed text-muted">
			<li>building for developers</li>
			<li>improving onboarding</li>
			<li>reducing "wtf do I use?" moments</li>
			<li>helping docs, community, and product actually make sense together</li>
		</ul>
		<p class="mb-6 leading-relaxed">
			Sometimes I even ship things people use and like, which is always a nice surprise
		</p>
		<div class="mb-8">
			<ul class="mb-4 list-disc space-y-2 ps-5 leading-relaxed text-muted"></ul>

			<p class="mb-8 leading-relaxed">I post like twice a month, but DMs are always welcome</p>

			<SocialList />
		</div>
		<section>
			<div class="mb-6 flex items-center gap-4">
				<div class="h-1 w-8 bg-accent/50"></div>
				<h2 class="text-xl font-semibold">Check Out</h2>
			</div>

			<div class="grid gap-4 sm:grid-cols-2">
				<a
					class="group flex items-start gap-4 rounded-xl border border-border bg-surface/30 p-5 transition-all duration-300 hover:border-accent/50 hover:bg-surface/50"
					href="https://exa.ai/"
					rel="noopener noreferrer"
					target="_blank"
				>
					<div class="rounded-lg bg-accent/10 p-3">
						<img alt="Exa logo" class="exa-logo-mark h-6 w-6" src={exaLogo.src} />
					</div>
					<div class="flex-1">
						<div class="mb-1 flex items-center gap-2">
							<h3 class="font-semibold group-hover:text-accent">Exa Labs</h3>
							<Icon
								class="h-4 w-4 text-muted transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-accent"
								is:inline
								name="mdi:arrow-top-right"
							/>
						</div>
						<p class="text-sm text-muted">Where I work on some cool stuff</p>
					</div>
				</a>

				<a
					class="group flex items-start gap-4 rounded-xl border border-border bg-surface/30 p-5 transition-all duration-300 hover:border-accent/50 hover:bg-surface/50"
					href="/projects/"
				>
					<div class="rounded-lg bg-accent/10 p-3">
						<Brackets class="text-accent" size={24} />
					</div>
					<div class="flex-1">
						<div class="mb-1 flex items-center gap-2">
							<h3 class="font-semibold group-hover:text-accent">My Projects</h3>
							<Icon
								class="h-4 w-4 text-muted transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-accent"
								is:inline
								name="mdi:arrow-top-right"
							/>
						</div>
						<p class="text-sm text-muted">See what I've been building</p>
					</div>
				</a>
			</div>
		</section>
	</section>
</PageLayout>

<style>
	.exa-logo-mark {
		transform-origin: center;
		transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
	}

	:global(.group:hover) .exa-logo-mark {
		transform: translateY(-2px) rotate(-8deg) scale(1.08);
	}

	@media (prefers-reduced-motion: reduce) {
		.exa-logo-mark {
			transition: none;
		}

		:global(.group:hover) .exa-logo-mark {
			transform: none;
		}
	}
</style>
