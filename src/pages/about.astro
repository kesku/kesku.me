---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

import ClawdPeek from "@/components/ClawdPeek.astro";
import aboutImgIsukash from "@/assets/about-kesku-isukash.png";
import aboutImg from "@/assets/about-kesku.png";
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description:
		"UK-based developer working at Perplexity AI on developer platform and ecosystem systems.",
	title: "About",
};

const games = [
	{ link: "https://store.steampowered.com/app/2988580/", name: "Yakuza" },
	{ link: "https://zenless.hoyoverse.com/", name: "Zenless Zone Zero" },
	{ link: "https://store.steampowered.com/app/1091500/", name: "Cyberpunk 2077" },
	{ link: "https://store.steampowered.com/app/3240220/", name: "GTA Online" },
	{ link: "https://www.minecraft.net/", name: "Minecraft" },
];

const socials = [
	{ icon: "mdi:github", link: "https://github.com/kesku", name: "GitHub" },
	{ icon: "mdi:twitter", link: "https://x.com/yoimnotkesku", name: "Twitter" },
	{ icon: "mdi:discord", link: "https://discordapp.com/users/539468067923820546", name: "Discord" },
	{ extra: "admin@kesku.me", icon: "mdi:email", link: "mailto:admin@kesku.me", name: "Email" },
];

const gamesListHtml = games
	.map((game, I) => {
		const separator = I < games.length - 2 ? ", " : I === games.length - 2 ? ", and " : "";
		return `<a href="${game.link}" target="_blank" rel="noopener noreferrer" class="text-accent transition-all hover:underline hover:underline-offset-2">${game.name}</a>${separator}`;
	})
	.join("");
---

<style>
	.attribution-container .attribution-isukash {
		pointer-events: none;
	}

	.image-wrapper[data-flipped="true"] .flip-inner {
		transform: rotateY(180deg);
	}
	.image-wrapper[data-flipped="true"] .attribution-container .attribution-romye {
		opacity: 0;
		pointer-events: none;
	}
	.image-wrapper[data-flipped="true"] .attribution-container .attribution-isukash {
		opacity: 1;
		pointer-events: auto;
	}
</style>

<script data-cfasync="false" data-pagespeed-no-defer is:inline>
	(function () {
		"use strict";
		let imageHovered = false;
		let handlers = {};
		let initAttempts = 0;
		const MAX_ATTEMPTS = 10;

		function initImageHover() {
			initAttempts++;
			const wrapper = document.querySelector(".image-wrapper");
			const imageContainer = wrapper?.querySelector(".image-container");
			const attributionContainer = wrapper?.querySelector(".attribution-container");

			if (!wrapper || !imageContainer || !attributionContainer) {
				if (initAttempts < MAX_ATTEMPTS && document.readyState !== "complete") {
					setTimeout(initImageHover, 100);
				}
				return;
			}

			if (handlers.imageEnter) {
				imageContainer.removeEventListener("mouseenter", handlers.imageEnter);
				wrapper.removeEventListener("mouseleave", handlers.wrapperLeave);
				attributionContainer.removeEventListener("mouseenter", handlers.attrEnter);
			}

			imageHovered = false;
			wrapper.removeAttribute("data-flipped");
			initAttempts = 0;

			handlers.imageEnter = function () {
				imageHovered = true;
				wrapper.setAttribute("data-flipped", "true");
			};

			handlers.wrapperLeave = function () {
				imageHovered = false;
				wrapper.removeAttribute("data-flipped");
			};

			handlers.attrEnter = function () {
				if (imageHovered) {
					wrapper.setAttribute("data-flipped", "true");
				}
			};

			imageContainer.addEventListener("mouseenter", handlers.imageEnter);
			wrapper.addEventListener("mouseleave", handlers.wrapperLeave);
			attributionContainer.addEventListener("mouseenter", handlers.attrEnter);
		}

		function setup() {
			if (typeof document === "undefined") return;

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", function () {
					setTimeout(initImageHover, 0);
				});
			} else if (document.readyState === "interactive" || document.readyState === "complete") {
				setTimeout(initImageHover, 0);
			} else {
				setTimeout(initImageHover, 100);
			}
		}

		setup();

		if (typeof document !== "undefined") {
			document.addEventListener("astro:page-load", function () {
				initAttempts = 0;
				setTimeout(initImageHover, 0);
			});
			document.addEventListener("astro:after-swap", function () {
				initAttempts = 0;
				setTimeout(initImageHover, 0);
			});
		}
	})();
</script>

<PageLayout meta={meta}>
	<section class="mb-12">
		<div class="mb-8 flex items-center gap-4">
			<div class="h-1 w-12 bg-accent"></div>
			<span class="text-sm font-medium uppercase tracking-widest text-accent">About</span>
		</div>

		<div class="flex flex-col gap-8 sm:flex-row sm:items-start">
			<div class="image-wrapper shrink-0">
				<div
					class="image-container relative h-[180px] w-[180px] cursor-pointer [perspective:1000px]"
				>
					<div
						class="flip-inner relative h-full w-full transition-transform duration-500 [transform-style:preserve-3d]"
					>
						<div class="absolute inset-0 [backface-visibility:hidden]">
							<Image
								alt="Profile picture of Kesku"
								class="h-full w-full rounded-xl border border-border object-cover"
								densities={[1, 2]}
								fetchpriority="high"
								loading="eager"
								src={aboutImg}
								width={400}
							/>
						</div>
						<div class="absolute inset-0 [backface-visibility:hidden] [transform:rotateY(180deg)]">
							<Image
								alt="Profile picture of Kesku, art is of Usada Pekora from Hololive by @isukash"
								class="h-full w-full rounded-xl border border-border object-cover"
								densities={[1, 2]}
								src={aboutImgIsukash}
								width={400}
							/>
						</div>
					</div>
				</div>
				<div class="attribution-container relative mt-2">
					<p
						class="attribution-romye text-center text-xs text-muted opacity-100 transition-opacity duration-300"
					>
						Art by <a
							class="text-accent transition-all hover:underline hover:underline-offset-2"
							href="https://x.com/romye_99"
							rel="noopener noreferrer"
							target="_blank">@romye_99</a
						>
					</p>
					<p
						class="attribution-isukash absolute inset-x-0 top-0 text-center text-xs text-muted opacity-0 transition-opacity duration-300"
					>
						Art by <a
							class="text-accent transition-all hover:underline hover:underline-offset-2"
							href="https://twitter.com/isukash"
							rel="noopener noreferrer"
							target="_blank">@isukash</a
						>
					</p>
				</div>
			</div>

			<div>
				<p class="mb-4 text-textColor">
					UK-based developer working @ <a
						class="text-accent transition-all hover:underline hover:underline-offset-2"
						href="https://www.perplexity.ai/"
						rel="noopener noreferrer"
						target="_blank">Perplexity AI</a
					>. I work on developer platform and ecosystem systems sitting somewhere between product,
					engineering, and community
				</p>
				<p class="text-muted">
					most of what I do is focused on taking things that are technically powerful and making
					them actually usable by developers, both pros and
					<ClawdPeek phraseClass="text-accent">claudophiles</ClawdPeek>
				</p>
			</div>
		</div>
	</section>

	<section class="mb-12">
		<div class="mb-6 flex items-center gap-4">
			<div class="h-1 w-8 bg-accent/50"></div>
			<h2 class="text-xl font-semibold">What I actually work on</h2>
		</div>

		<ul class="mb-6 list-disc ps-5 text-muted">
			<li>improving developer onboarding and post-onboarding experience</li>
			<li>reducing confusion across api surfaces and docs</li>
			<li>building systems for community → support → product feedback</li>
			<li>open source integrations and developer tooling (sdks, cli, mcps)</li>
		</ul>
	</section>

	<section class="mb-12">
		<div class="mb-6 flex items-center gap-4">
			<div class="h-1 w-8 bg-accent/50"></div>
			<h2 class="text-xl font-semibold">What I'm Into</h2>
		</div>

		<div class="grid gap-6 sm:grid-cols-2">
			<div class="rounded-xl border border-border bg-surface/30 p-6">
				<Icon class="mb-3 h-8 w-8 text-accent" name="mdi:controller" />
				<h3 class="mb-2 font-semibold">Gaming</h3>
				<p class="mb-4 text-sm text-muted" set:html={`Big fan of ${gamesListHtml}.`} />
				<p class="mb-4 text-sm text-muted">
					as a kid, I'd play till late at night, and minecraft was all I dreamt about. now the music
					sends me back in time when I hear it, and with vr (through <a
						class="text-accent transition-all hover:underline hover:underline-offset-2"
						href="https://www.vivecraft.org/"
						rel="noopener noreferrer"
						target="_blank">Vivecraft</a
					>), I'm closer to it than ever.
				</p>
				<p class="text-sm text-muted">
					BTW: I use a <a
						class="text-accent transition-all hover:underline hover:underline-offset-2"
						href="https://varjo.com/products/varjo-vr-3"
						rel="noopener noreferrer"
						target="_blank">Varjo VR-3</a
					> for my VR gaming.
				</p>
			</div>

			<div class="rounded-xl border border-border bg-surface/30 p-6">
				<Icon class="mb-3 h-8 w-8 text-accent" name="mdi:account-group" />
				<h3 class="mb-2 font-semibold">Community</h3>
				<p class="mb-4 text-sm text-muted">
					Moderating communities since I was 11, starting on old <a
						class="text-accent transition-all hover:underline hover:underline-offset-2"
						href="https://www.perplexity.ai/search/what-was-the-amino-app-ZfVunsx2Tfe8tdQlK39GoA#0"
						rel="noopener noreferrer"
						target="_blank">Amino forums</a
					>.
				</p>
				<p class="mb-4 text-sm text-muted">
					later helped scale the <a
						class="text-accent transition-all hover:underline hover:underline-offset-2"
						href="https://discord.gg/openai"
						rel="noopener noreferrer"
						target="_blank">OpenAI Discord</a
					> to ~3.5m users (at one point the 2nd largest server on the platform).
				</p>
				<p class="text-sm text-muted">
					I'm interested in how they function as systems, not just for engagement, but also
					knowledge distribution (shoutout <a
						class="text-accent transition-all hover:underline hover:underline-offset-2"
						href="https://www.answeroverflow.com/"
						rel="noopener noreferrer"
						target="_blank">answer overflow</a
					>), support, and feedback loops.
				</p>
			</div>
		</div>
	</section>

	<section class="mb-12">
		<div class="mb-6 flex items-center gap-4">
			<div class="h-1 w-8 bg-accent/50"></div>
			<h2 class="text-xl font-semibold">"Kesku" is an acronym</h2>
		</div>

		<p class="mb-4 text-textColor">
			"kesku" stands for <span class="font-semibold text-accent"
				>Keep Everything Simple, Keep Understanding</span
			>.
		</p>
		<p class="text-muted">
			that mindset guides everything I do. if something is powerful but still hard to get, it’s not
			done. I want to understand both what it is and why it works; if I can’t, it needs clearer
			explanations and better examples.
		</p>
	</section>

	<section class="mb-12">
		<div class="mb-6 flex items-center gap-4">
			<div class="h-1 w-8 bg-accent/50"></div>
			<h2 class="text-xl font-semibold">Connect</h2>
		</div>

		<ul class="flex flex-wrap items-center gap-4">
			{
				socials.map(({ extra, icon, link, name }) => (
					<li>
						<a
							class="group flex items-center gap-2 rounded-lg border border-accent/30 bg-accent/5 px-4 py-2 transition-all duration-300 hover:border-accent hover:bg-accent/15"
							href={link}
							rel={link.startsWith("mailto:") ? undefined : "noopener noreferrer"}
							target={link.startsWith("mailto:") ? undefined : "_blank"}
						>
							<Icon
								aria-hidden="true"
								class="h-5 w-5 text-accent transition-transform group-hover:scale-110"
								focusable="false"
								name={icon}
							/>
							<span class="text-sm font-medium">{name}</span>
							{extra && <span class="text-xs text-muted">({extra})</span>}
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
